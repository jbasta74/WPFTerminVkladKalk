<Window x:Class="WPFTerminVkladKalk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFTerminVkladKalk"
        mc:Ignorable="d"
        Icon="/Resources/ikonka.ico"
        Title="Kalkulačka vkladů" Height="450" Width="600" MinWidth="600" MinHeight="450">

    <Window.CommandBindings>
        <CommandBinding Command="Save" Executed="BtnExportTxt_Click" />
        <CommandBinding Command="Delete" Executed="BtnSmazat_Click" />
    </Window.CommandBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="White" Padding="2" BorderBrush="LightGray" BorderThickness="0,0,0,1">
            <MenuItem Header="_Soubor">
                <MenuItem Header="_Exportovat do TXT" Command="Save" InputGestureText="Ctrl+S">
                    <MenuItem.Icon>
                        <TextBlock Text="💾" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Ukončit" Click="MenuUkoncit_Click" />
            </MenuItem>
            <MenuItem Header="_Úpravy">
                <MenuItem Header="_Smazat celou historii" Command="Delete" Foreground="Red" />
            </MenuItem>
            <MenuItem Header="_Nápověda">
                <MenuItem Header="_O aplikaci" Click="MenuOApp_Click" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <GroupBox Header="Parametry vkladu" Padding="8" Background="#F9F9F9">
                    <StackPanel>
                        <Label Content="Vklad (Kč):" FontWeight="Bold"/>
                        <TextBox x:Name="txtVklad" Text="100000" Margin="0,0,0,5" Padding="3"/>

                        <Label Content="Úrok p.a. (%):" FontWeight="Bold"/>
                        <TextBox x:Name="txtUrok" Text="5" Margin="0,0,0,5" Padding="3"/>

                        <Label Content="Doba (měsíce):" FontWeight="Bold"/>
                        <TextBox x:Name="txtMesice" Text="12" Margin="0,0,0,5" Padding="3"/>

                        <Button Content="VYPOČÍTAT" Margin="0,15,0,0" Click="BtnVypocitat_Click" 
                                Height="40" Background="LightGreen" FontWeight="Bold" Cursor="Hand">
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                            </Button.Effect>
                        </Button>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="Tip: Výpočet probíhá dle standardu ACT/360 se srážkovou daní 15 %." 
                           TextWrapping="Wrap" Margin="5,20,5,0" FontSize="11" Foreground="Gray" FontStyle="Italic"/>
            </StackPanel>

            <GroupBox Grid.Column="1" Header="Historie výpočtů">
                <DataGrid x:Name="dgHistorie" AutoGenerateColumns="False" IsReadOnly="True" 
                          AlternatingRowBackground="#F2F2F2" GridLinesVisibility="None" 
                          BorderThickness="1" BorderBrush="LightGray">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Zadáno" Binding="{Binding DatumVkladu, StringFormat={}{0:dd.MM. HH:mm}}" Width="Auto"/>

                        <DataGridTextColumn Header="Vklad" Binding="{Binding Vklad, StringFormat={}{0:N0} Kč}" Width="*"/>

                        <DataGridTextColumn Header="Úrok %" Binding="{Binding UrokPa}" Width="Auto"/>

                        <DataGridTextColumn Header="Čistý zisk" Binding="{Binding CistyUrok, StringFormat={}{0:N2} Kč}" FontWeight="Bold" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="Green"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Splatnost" Binding="{Binding DatumSplatnosti, StringFormat={}{0:dd.MM.yyyy}}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
