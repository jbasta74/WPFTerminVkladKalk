<Window x:Class="WPFTerminVkladKalk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFTerminVkladKalk"
        mc:Ignorable="d"
        Title="Kalkulačka vkladů" Height="450" Width="600" MinWidth="600" MinHeight="450">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveTxtCommand}"/>
    </Window.InputBindings>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">

            <GroupBox Header="Parametry vkladu" Padding="5">
                <StackPanel>
                    <Label Content="Vklad (Kč):" FontWeight="Bold"/>
                    <TextBox x:Name="txtVklad" Text="100000"/>
                    <Label Content="Úrok p.a. (%):" FontWeight="Bold"/>
                    <TextBox x:Name="txtUrok" Text="5"/>
                    <Label Content="Doba (měsíce):" FontWeight="Bold"/>
                    <TextBox x:Name="txtMesice" Text="12" VerticalContentAlignment="Center"/>
                    <Button Content="VYPOČÍTAT" Margin="0,15,0,0" Click="BtnVypocitat_Click" Height="35" Background="LightGreen" FontWeight="Bold"/>
                </StackPanel>
            </GroupBox>

            <Button Content="Exportovat do TXT (Ctrl+S)" Margin="0,20,0,0" Click="BtnExportTxt_Click"/>
            <Button Content="Smazat celou historii" Margin="0,10,0,0" Click="BtnSmazat_Click" Foreground="Red"/>
        </StackPanel>

        <DataGrid Grid.Column="1" x:Name="dgHistorie" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Datum" Binding="{Binding Datum, StringFormat={}{0:dd.MM. HH:mm}}"/>
                <DataGridTextColumn Header="Vklad" Binding="{Binding Vklad, StringFormat={}{0:N0} Kč}"/>
                <DataGridTextColumn Header="Úrok %" Binding="{Binding UrokPa}"/>
                <DataGridTextColumn Header="Čistý zisk" Binding="{Binding CistyUrok, StringFormat={}{0:N2} Kč}"/>
                <DataGridTextColumn Header="Dní (ACT)" Binding="{Binding PocetDni}"/>
                <DataGridTextColumn Header="Splatnost" Binding="{Binding DatumSplatnosti, StringFormat={}{0:dd.MM.yyyy}}"/>

            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
